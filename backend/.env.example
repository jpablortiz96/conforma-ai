# Conforma-AI backend environment
# Copy this file to backend/.env and set real values locally.
# Do not commit backend/.env.
#
# Vultr note for future deploy work:
# VULTR_VM_IP=replace-with-your-frankfurt-vm-ip-on-d6

APP_ENV=development
APP_NAME=conforma-ai
APP_VERSION=0.1.0

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=30

DATABASE_URL=postgresql://conforma:conforma_dev_password@localhost:5432/conforma_ai
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-this-with-a-random-string
